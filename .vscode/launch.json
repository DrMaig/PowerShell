{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PowerShell: Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "cwd": "${fileDirname}",
            "createTemporaryIntegratedConsole": true
        },
        {
            "name": "PowerShell: Launch Current File (No Debug)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "cwd": "${fileDirname}",
            "createTemporaryIntegratedConsole": true
        },
        {
            "name": "PowerShell: Debug Profile",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Microsoft.PowerShell_profile.ps1",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "PowerShell: Pre-Debug Profile Checks",
            "createTemporaryIntegratedConsole": true
        },
        {
            "name": "PowerShell: Debug Tests (run_pester.ps1)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Scripts/run_pester.ps1",
            "cwd": "${workspaceFolder}",
            "createTemporaryIntegratedConsole": true
        },
        {
            "name": "PowerShell: Debug Pester Test File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Microsoft.PowerShell_profile.Tests.ps1",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "PowerShell: Parse Check Profile",
            "createTemporaryIntegratedConsole": true
        },
        {
            "name": "PowerShell: Attach to Host Process",
            "type": "PowerShell",
            "request": "attach"
        }
    ]
}